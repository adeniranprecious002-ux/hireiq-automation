        "responses": {
          "values": [
            {
              "role": "system",
              "content": "=You are a senior technical recruiter with 10+ years of experience evaluating candidates across tech, data, and operations roles.\n\nYou will be given a job description and a candidate's resume. Your task is to objectively score and evaluate the candidate's fit.\n\n---\n\nJOB DESCRIPTION:\n{{ $json.job_description }}\n\n---\n\nCANDIDATE RESUME:\n{{ $json.resume_text }}\n\n---\n\nRespond ONLY with a valid JSON object in this exact format, no extra text:\n\n{\n  \"candidate_name\": \"extracted from resume or 'Unknown'\",\n  \"score\": <integer 0-100>,\n  \"recommendation\": \"<one of: Strong Hire | Lean Hire | Maybe | Lean Reject | Reject>\",\n  \"summary\": \"<2-3 sentence overall assessment>\",\n  \"strengths\": [\n    \"<strength 1>\",\n    \"<strength 2>\",\n    \"<strength 3>\"\n  ],\n  \"weaknesses\": [\n    \"<weakness 1>\",\n    \"<weakness 2>\",\n    \"<weakness 3>\"\n  ],\n  \"skill_match\": {\n    \"required_skills_found\": [\"<skill1>\", \"<skill2>\"],\n    \"required_skills_missing\": [\"<skill1>\", \"<skill2>\"],\n    \"bonus_skills_found\": [\"<skill1>\"]\n  },\n  \"experience_match\": \"<Exceeds Requirements | Meets Requirements | Partially Meets | Does Not Meet>\",\n  \"culture_fit_notes\": \"<brief note on soft skills, communication style, career trajectory>\",\n  \"red_flags\": [\"<any concerns, or empty array if none>\"]\n}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [
        432,
        -288
      ],
      "id": "64ddd1a7-8c64-4a13-9921-88b9c6b7282f",
      "name": "Message a model",
      "credentials": {
        "openAiApi": {
          "id": "zGgDovBFFbp9MHPb",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst candidates = items.map(item => {\n  // Get the raw text from OpenAI response\n  const rawText = item.json.output?.[0]?.content?.[0]?.text || \n                  item.json.content?.[0]?.text || \n                  item.json.text || '';\n  \n  // Parse the JSON from the text\n  let candidate = {};\n  try {\n    const cleaned = rawText.replace(/```json|```/g, '').trim();\n    candidate = JSON.parse(cleaned);\n  } catch(e) {\n    candidate = { \n      candidate_name: 'Parse Error', \n      score: 0,\n      recommendation: 'Error',\n      summary: rawText.substring(0, 100)\n    };\n  }\n  \n  return candidate;\n});\n\n// Sort by score descending\nconst ranked = candidates\n  .sort((a, b) => (b.score || 0) - (a.score || 0))\n  .map((c, i) => ({\n    ...c,\n    rank: i + 1,\n    tier: c.score >= 75 ? '🟢 Fast Track' \n        : c.score >= 50 ? '🟡 Review' \n        : '🔴 Reject',\n    strengths: Array.isArray(c.strengths) ? c.strengths.join(', ') : '',\n    weaknesses: Array.isArray(c.weaknesses) ? c.weaknesses.join(', ') : '',\n    skills_found: c.skill_match?.required_skills_found?.join(', ') || '',\n    skills_missing: c.skill_match?.required_skills_missing?.join(', ') || '',\n    red_flags: Array.isArray(c.red_flags) ? c.red_flags.join(', ') : '',\n    processed_at: new Date().toISOString()\n  }));\n\nreturn ranked.map(c => ({ json: c }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        752,
        -416
      ],
      "id": "78e5b0c0-96a9-430d-84a0-6fa39bce3592",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\nconst ip = $json.headers['x-forwarded-for'] || $json.headers['x-real-ip'] || 'unknown';\n\nif (!staticData.requests) {\n  staticData.requests = {};\n}\n\nconst now = Date.now();\nconst windowTime = 60 * 60 * 1000; // 60 minutes\n\nif (!staticData.requests[ip]) {\n  staticData.requests[ip] = [];\n}\n\n// Remove old requests outside the time window\nstaticData.requests[ip] = staticData.requests[ip].filter(\n  t => now - t < windowTime\n);\n\n// Add current request\nstaticData.requests[ip].push(now);\n\nconst requestCount = staticData.requests[ip].length;\n\n// Return JSON AND preserve the binary file\nreturn [{\n  json: {\n    ip,\n    requestCount,\n    job_description: $json.body?.job_description || $json.job_description || ''\n  },\n  binary: $input.first().binary  // ← preserves the PDF\n}];"
      },
