    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Data is already flat from Google Sheets node\nconst candidates = items.filter(item => \n  item.json['Candidate Name'] || item.json.candidate_name\n);\n\nconst getName = (item) => item.json['Candidate Name'] || item.json.candidate_name || '';\nconst getScore = (item) => Number(item.json['Score'] || item.json.score || 0);\n\nconst fastTrack = candidates.filter(c => getScore(c) >= 75).length;\nconst review = candidates.filter(c => getScore(c) >= 50 && getScore(c) < 75).length;\nconst rejected = candidates.filter(c => getScore(c) < 50).length;\nconst avgScore = candidates.length > 0 \n  ? Math.round(candidates.reduce((sum, c) => sum + getScore(c), 0) / candidates.length)\n  : 0;\n\nconst topCandidate = [...candidates].sort((a, b) => getScore(b) - getScore(a))[0];\n\nreturn [{\n  json: {\n    job_title: 'Data Analyst',\n    total_candidates: candidates.length,\n    fast_track: fastTrack,\n    review: review,\n    rejected: rejected,\n    average_score: avgScore,\n    top_candidate: getName(topCandidate) || 'N/A',\n    run_date: new Date().toISOString().split('T')[0]\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1168,
        -240
      ],
      "id": "b62398e5-ebee-4512-a422-c71e3815acf5",
      "name": "Code in JavaScript3"
    },
    {
      "parameters": {
        "jsCode": "// Get batch summary\nconst summary = $('Code in JavaScript3').first().json;\n\n// Get all ranked candidates\nconst candidates = $('Code in JavaScript').all().map(i => i.json);\n\nreturn [{\n  json: {\n    success: true,\n    total: summary.total_candidates,\n    fast_track: summary.fast_track,\n    review: summary.review,\n    rejected: summary.rejected,\n    average_score: summary.average_score,\n    top_candidate: summary.top_candidate,\n    run_date: summary.run_date,\n    candidates: candidates\n  }\n}];"
      },
