    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst firstItem = items[0];\n\n// Get all binary keys (resumes0, resumes1, resumes2 etc.)\nconst binaryKeys = Object.keys(firstItem.binary || {})\n  .filter(key => key.startsWith('resumes'));\n\n// Create one item per resume, each with binary field named 'data'\nreturn binaryKeys.map(key => ({\n  json: {\n    job_description: firstItem.json.job_description || '',\n    original_filename: firstItem.binary[key].fileName || key\n  },\n  binary: {\n    data: firstItem.binary[key]  // rename to 'data' for Extract from File\n  }\n}));"
      },
